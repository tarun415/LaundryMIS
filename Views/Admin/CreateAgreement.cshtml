@model LaudaryMis.ViewModels.AgreementVM

<div class="container mt-4">
    <h3>📄 Create Agreement</h3>

    <form method="post" enctype="multipart/form-data">

        <div class="mb-3">
            <label>Provider</label>
            <select asp-for="ProviderId" class="form-control">
                @foreach (var p in Model.Providers)
                {
                    <option value="@p.ProviderId">@p.ProviderName</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label>Hospital</label>
            <select asp-for="HospitalId" class="form-control">
                @foreach (var h in Model.Hospitals)
                {
                    <option value="@h.HospitalId">@h.HospitalName</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label>Bed Count</label>
            <input asp-for="BedCount" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Rate Per Bed</label>
            <input asp-for="RatePerBed" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" />
        </div>

        <div class="mb-3">
            <label>End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Upload Agreement</label>
            <input type="file" name="AgreementFile" class="form-control" />
        </div>

        <button class="btn btn-success">Save</button>

    </form>
</div>