@model LaudaryMis.ViewModels.AgreementVM

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-3">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">📄 Create Agreement</h4>
        </div>

        <div class="card-body">
            <form method="post" enctype="multipart/form-data">

                <div class="row">

                    <!-- Provider -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Provider</label>
                        <select asp-for="ProviderId" class="form-select">
                            <option value="">-- Select Provider --</option>
                            @foreach (var p in Model.Providers)
                            {
                                <option value="@p.ProviderId">@p.ProviderName</option>
                            }
                        </select>
                    </div>

                    <!-- Hospital -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Hospital</label>
                        <select asp-for="HospitalId" class="form-select">
                            <option value="">-- Select Hospital --</option>
                            @foreach (var h in Model.Hospitals)
                            {
                                <option value="@h.HospitalId">@h.HospitalName</option>
                            }
                        </select>
                    </div>

                    <!-- Bed Count -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Bed Count</label>
                        <input asp-for="BedCount" class="form-control" placeholder="Enter total beds" />
                    </div>

                    <!-- Rate -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Rate Per Bed (₹)</label>
                        <input asp-for="RatePerBed" class="form-control" placeholder="Enter rate per bed" />
                    </div>

                    <!-- Start Date -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Start Date</label>
                        <input asp-for="StartDate" type="date" class="form-control" />
                    </div>

                    <!-- End Date -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">End Date</label>
                        <input asp-for="EndDate" type="date" class="form-control" />
                    </div>

                    <!-- File Upload -->
                    <div class="col-12 mb-4">
                        <label class="form-label fw-semibold">Upload Agreement</label>
                        <input type="file" name="AgreementFile" class="form-control" />
                        <small class="text-muted">Upload PDF or document file</small>
                    </div>

                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end">
                    <button type="reset" class="btn btn-outline-secondary me-2">
                        Reset
                    </button>
                    <button type="submit" class="btn btn-success px-4">
                        💾 Save Agreement
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>