@model IEnumerable<LaudaryMis.ViewModels.ProvidersVM>

@{
    ViewBag.Title = "Provider List";
}

<!-- ✅ Bootstrap -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

<!-- ✅ DataTables -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css" />

<!-- ✅ Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<!-- ✅ jQuery -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

<!-- ✅ Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- ✅ DataTables -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<!-- ✅ Buttons -->
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<!-- 🔥 Custom Styling -->
<style>


    /* Add button */
    .btn-primary {
        background: linear-gradient(135deg, #3b82f6, #1e40af);
        border: none;
        color: #fff;
        font-weight: 500;
    }

    /* DataTable Buttons */
    .dt-buttons {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-right: 10px;
    }

        .dt-buttons .btn {
            width: 34px;
            height: 34px;
            border-radius: 50% !important;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 !important;
            border: none !important;
            color: #fff !important;
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
            transition: 0.2s;
            font-size: 14px;
        }

    .buttons-copy {
        background: #6c757d !important;
    }

    .buttons-excel {
        background: #198754 !important;
    }

    .buttons-pdf {
        background: #dc3545 !important;
    }

    .buttons-print {
        background: #0d6efd !important;
    }

    .dt-buttons .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 12px rgba(0,0,0,0.2);
    }

    /* Search box */
    .dataTables_filter input {
        width: 180px !important;
        border-radius: 20px;
        padding: 6px 12px;
        border: 1px solid #ddd;
    }

    /* Table spacing */
    table.dataTable td, table.dataTable th {
        padding: 8px 12px !important;
        font-size: 14px;
    }
</style>

<div class="main-container">

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">🏥 Provider List</h4>

                <a href="/Admin/CreateProvider" class="btn btn-primary rounded-pill px-4">
                    + Add Providers
                </a>
            </div>

            <div class="table-responsive">
                <table id="providerTable" class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Provider Name</th>
                            <th>Rate</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var h in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@h.ProviderName</td>
                                <td>@h.RatePerBed</td>
                                <td>
                                    @if (h.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill">
                                            Inactive
                                        </span>
                                    }
                                </td>
                                <td>
                                    <!-- Edit -->
                                    <a href="/Admin/EditProvider/@h.ProviderId"
                                       class="btn btn-sm btn-warning rounded-pill px-3 me-1">
                                        <i class="fa fa-edit"></i>
                                    </a>

                                    <!-- Delete -->
                                    <button class="btn btn-sm btn-danger rounded-pill px-3"
                                            onclick="deleteProvider(@h.ProviderId, this)">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- 🔥 DataTable Script -->
<script>
    $(document).ready(function () {
        $('#providerTable').DataTable({
            pageLength: 10,
            responsive: true,
            autoWidth: false,

            dom:
                "<'row mb-2 align-items-center'<'col-md-4'l><'col-md-8 d-flex justify-content-end align-items-center gap-2'Bf>>" +
                "<'row'<'col-12'tr>>" +
                "<'row mt-2'<'col-md-5'i><'col-md-7 text-end'p>>",

            buttons: [
                {
                    extend: 'copy',
                    className: 'btn buttons-copy',
                    text: '<i class="fa fa-copy"></i>',
                    titleAttr: 'Copy'
                },
                {
                    extend: 'excel',
                    className: 'btn buttons-excel',
                    text: '<i class="fa fa-file-excel"></i>',
                    titleAttr: 'Excel'
                },
                {
                    extend: 'pdf',
                    className: 'btn buttons-pdf',
                    text: '<i class="fa fa-file-pdf"></i>',
                    titleAttr: 'PDF'
                },
                {
                    extend: 'print',
                    className: 'btn buttons-print',
                    text: '<i class="fa fa-print"></i>',
                    titleAttr: 'Print'
                }
            ],

            language: {
                search: "",
                searchPlaceholder: "🔍 Search..."
            }
        });
    });
</script>
<script>
    function deleteProvider(id, btn) {
        if (confirm("Are you sure you want to delete this provider?")) {

            $.post('/Admin/DeleteProvider', { id: id }, function (res) {

                if (res.success) {
                    $(btn).closest('tr').fadeOut(); // remove row smoothly
                } else {
                    alert(res.message || "Delete failed");
                }

            });

        }
    }
</script>