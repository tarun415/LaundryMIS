@model LaudaryMis.ViewModels.DailyEntryEditVM

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <div class="card shadow-lg p-4">

        <h4 class="fw-bold mb-3">Edit Linen Entry</h4>

        <form method="post">

            <input type="hidden" name="EntryId" value="@Model.EntryId" />

            <!-- PICKUP SECTION -->
            <h6 class="text-muted">Pickup Details</h6>

            <div class="row">

                <div class="col-md-4 mb-3">
                    <label class="form-label">Dirty Qty</label>
                    <input type="number" class="form-control qty" name="DirtyQty" value="@Model.DirtyQty" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Soiled Qty</label>
                    <input type="number" class="form-control qty" name="SoiledQty" value="@Model.SoiledQty" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Infected Qty</label>
                    <input type="number" class="form-control qty" name="InfectedQty" value="@Model.InfectedQty" />
                </div>

            </div>

            <!-- TOTAL AUTO -->
            <div class="mb-3">
                <label class="form-label">Total Pickup Qty</label>
                <input id="totalPickup" class="form-control bg-light"
                       value="@Model.TotalPickupQty" readonly />
            </div>

            <hr />

            <!-- DELIVERY SECTION -->
            <h6 class="text-muted">Delivery Details</h6>

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Delivered Qty</label>
                    <input type="number" class="form-control"
                           name="CleanDeliveredQty"
                           value="@Model.CleanDeliveredQty" />
                </div>

            </div>

            <!-- REMARKS -->
            <div class="mb-3">
                <label class="form-label">Remarks</label>
                <textarea class="form-control" name="Remarks" rows="3">@Model.Remarks</textarea>
            </div>

            <!-- BUTTONS -->
            <div class="d-flex justify-content-between">

                <a href="/Provider/DailyEntryList" class="btn btn-secondary">
                    ← Back
                </a>

                <button type="submit" class="btn btn-success">
                    Update Entry
                </button>

            </div>

        </form>

    </div>

</div>

<!-- AUTO CALCULATION SCRIPT -->
<script>
    document.querySelectorAll('.qty').forEach(el => {
        el.addEventListener('input', () => {

            let d = parseInt(document.querySelector('[name=DirtyQty]').value) || 0;
            let s = parseInt(document.querySelector('[name=SoiledQty]').value) || 0;
            let i = parseInt(document.querySelector('[name=InfectedQty]').value) || 0;

            document.getElementById('totalPickup').value = d + s + i;
        });
    });
</script>