@model List<LaudaryMis.ViewModels.DailyEntryListVM>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">

    <!-- TITLE + BUTTON -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">Daily Linen Entries</h4>

        <a href="/Provider/DailyEntry" class="btn btn-primary">
            + New Entry
        </a>
    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    <!-- TABLE CARD -->
    <div class="card shadow-sm">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Hospital</th>
                        <th>Ward</th>
                        <th>Linen</th>
                        <th>Pickup</th>
                        <th>Delivered</th>
                        <th>Status</th>
                        <th width="120">Action</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">
                                No records found
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.EntryDate.ToString("dd MMM yyyy")</td>

                            <td class="fw-semibold">@item.HospitalName</td>

                            <td>@item.WardName</td>

                            <td>
                                <span class="badge bg-secondary">
                                    @item.LinenTypeName
                                </span>
                            </td>

                            <td>
                                <span class="text-primary fw-bold">
                                    @item.TotalPickupQty
                                </span>
                            </td>

                            <td>
                                <span class="text-success fw-bold">
                                    @item.CleanDeliveredQty
                                </span>
                            </td>

                            <!-- STATUS BADGE -->
                            <td>
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (item.Status == "Delivered")
                                {
                                    <span class="badge bg-info text-dark">Delivered</span>
                                }
                                else if (item.Status == "Verified")
                                {
                                    <span class="badge bg-success">Verified</span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>

                            <!-- ACTION -->
                            <td>
                                <a href="/Provider/EditDailyEntry/@item.EntryId"
                                   class="btn btn-sm btn-outline-primary">
                                    Edit
                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>