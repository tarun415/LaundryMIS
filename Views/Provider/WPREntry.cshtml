                    <input class="form-control" id="w-staff" placeholder="Staff name">
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Remarks</label>
                <textarea class="form-control" id="w-remarks" rows="2" placeholder="Optional..."></textarea>
            </div>
        </div>
