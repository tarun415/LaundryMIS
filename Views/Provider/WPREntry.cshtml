                    <div style="font-size:13px;color:var(--slate);margin-top:4px;">out of 100</div>
                    <div class="score-meter" style="margin:14px 0 8px;"><div class="score-fill" id="wprScoreFill" style="width:0%"></div></div>
                    <div id="wprScoreLabel" style="font-size:13px;font-weight:600;color:var(--slate);">Score parameters below</div>
                </div>
            </div>
            <div class="notice-banner notice-warn" style="margin:0 0 12px;">
