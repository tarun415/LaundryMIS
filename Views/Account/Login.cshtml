@model LaudaryMis.ViewModels.LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Laundry MIS Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Font (IMPORTANT for same look) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at 20% 30%, #1c3b57, #0f2a44);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .container {
            width: 380px;
            background: #f9fbfc;
            padding: 30px;
            border-radius: 18px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.25);
            text-align: center;
        }

        .logo-box {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #0c6b75, #083b5c);
            border-radius: 16px;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        }

            .logo-box img {
                width: 40px;
            }

        h2 {
            margin-top: 15px;
            font-weight: 600;
            color: #1a2b3c;
        }

        .sub {
            font-size: 12px;
            color: #6c7a89;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }

        .role-container {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
        }

        .role {
            flex: 1;
            padding: 12px;
            border-radius: 12px;
            border: 2px solid #dce3e8;
            cursor: pointer;
            transition: 0.3s;
        }

            .role.active {
                border-color: #0c6b75;
                background: #e6f3f5;
            }

            .role img {
                width: 28px;
                margin-bottom: 5px;
            }

            .role span {
                display: block;
                font-weight: 600;
                color: #1a2b3c;
            }

            .role small {
                font-size: 11px;
                color: #6c7a89;
            }

        .label {
            text-align: left;
            font-size: 12px;
            font-weight: 600;
            margin-top: 10px;
            color: #1a2b3c;
        }

        input {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid #ccd6dd;
            margin-top: 5px;
            font-size: 14px;
        }

        .hint {
            text-align: left;
            font-size: 11px;
            color: #6c7a89;
        }

        button {
            width: 100%;
            padding: 12px;
            margin-top: 20px;
            border: none;
            border-radius: 12px;
            background: linear-gradient(135deg, #0c6b75, #083b5c);
            color: white;
            font-size: 15px;
            cursor: pointer;
        }

            button:hover {
                opacity: 0.9;
            }

        .error {
            color: red;
            font-size: 12px;
            margin-top: 10px;
        }
    </style>
</head>

<body>

    <div class="container">

        <!-- LOGO -->
        <div class="logo-box">
            <img src="https://cdn-icons-png.flaticon.com/512/2966/2966481.png" />
        </div>

        <h2>DGMH UP — Laundry MIS</h2>
        <div class="sub">GOVERNMENT OF UTTAR PRADESH · 197 DISTRICT HOSPITALS</div>

        <form method="post">

            <!-- ROLE SELECT -->
            <div class="role-container">
                <div class="role active" onclick="setRole(1,this)">
                    <img src="https://cdn-icons-png.flaticon.com/512/847/847969.png">
                    <span>Admin</span>
                    <small>DGMH / Authority</small>
                </div>

                <div class="role" onclick="setRole(2,this)">
                    <img src="https://cdn-icons-png.flaticon.com/512/2966/2966327.png">
                    <span>Hospital</span>
                    <small>CMS / SIC Staff</small>
                </div>
                <div class="role" onclick="setRole(3,this)">
                    <img src="https://cdn-icons-png.flaticon.com/512/2966/2966327.png">
                    <span>Provider</span>
                    <small>Provider </small>
                </div>
            </div>

            <input type="hidden" id="RoleId" name="RoleId" value="1" />

            <!-- USERNAME -->
            <div class="label">USERNAME</div>
            <input type="text" name="RoleName" placeholder="Enter username" />
            <div class="hint">Username: admin</div>

            <!-- PASSWORD -->
            <div class="label">PASSWORD</div>
            <input type="password" name="Password" placeholder="Enter password" />
            <div class="hint">Demo password: pass123</div>

            <button type="submit">Sign In →</button>

            <div class="error">
                @Html.ValidationSummary()
            </div>

        </form>
    </div>

    <script>
        function setRole(roleId, el) {
            document.getElementById("RoleId").value = roleId;
            document.querySelectorAll(".role").forEach(r => r.classList.remove("active"));
            el.classList.add("active");
        }
    </script>

</body>
</html>